{
  "name": "planview",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:web": "bun run --filter web dev",
    "dev:desktop": "bun run --filter desktop dev:hmr",
    "build:desktop": "bun run --filter desktop build:stable",
    "build:desktop:canary": "bun run --filter desktop build:canary"
  },
  "dependencies": {
    "@planview/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@planview/config": "workspace:*",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.4"
}
